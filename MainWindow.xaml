<Window x:Class="ProductMasterPlanV1.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ProductMasterPlan V1 Dashboard"
        Height="864"
        Width="1536"
        MinHeight="820"
        MinWidth="1450"
        WindowStartupLocation="CenterScreen"
        Background="#FFF7F3FF">

    <Window.Resources>
        <SolidColorBrush x:Key="CandyPurpleDark" Color="#FF5E35B1"/>
        <SolidColorBrush x:Key="CandyPanel" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="CandyBorder" Color="#FFE6DDF7"/>
        <SolidColorBrush x:Key="CandyText" Color="#FF2D1B4E"/>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CandyPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CandyBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Background" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Background" Value="#FFF1EAFE"/>
            <Setter Property="Foreground" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="BorderBrush" Value="#FFD8C8F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StepButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="54"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="Background" Value="#FFF3EEFF"/>
            <Setter Property="Foreground" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="BorderBrush" Value="#FFD8C8F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="StepperValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource CandyText}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ResultLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CandyPurpleDark}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,1"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ResultValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CandyText}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="SmallResultValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource CandyText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="IdentityTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderBrush" Value="#FFD8C8F4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.65*"/>
            <ColumnDefinition Width="1.1*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Identity" Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                            <TextBlock Text="User Key" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="UserKeyTextBox" Style="{StaticResource IdentityTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="6,0,6,0">
                            <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="NameTextBox" Style="{StaticResource IdentityTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="6,0,6,0">
                            <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="PhoneTextBox" Style="{StaticResource IdentityTextBoxStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="6,0,0,0">
                            <TextBlock Text="Email" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox x:Name="EmailTextBox" Style="{StaticResource IdentityTextBoxStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Financial Dashboard" Style="{StaticResource SectionHeaderStyle}"/>

                    <UniformGrid Columns="3" Rows="2">

                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF9F0FF">
                            <StackPanel>
                                <TextBlock Text="Age" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <TextBlock x:Name="AgeValueText" Text="0" Style="{StaticResource StepperValueStyle}"/>
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="-6" Style="{StaticResource StepButtonStyle}" Click="AgeMinus6_Click"/>
                                    <Button Content="-3" Style="{StaticResource StepButtonStyle}" Click="AgeMinus3_Click"/>
                                    <Button Content="-1" Style="{StaticResource StepButtonStyle}" Click="AgeMinus1_Click"/>
                                    <Button Content="+1" Style="{StaticResource StepButtonStyle}" Click="AgePlus1_Click"/>
                                    <Button Content="+3" Style="{StaticResource StepButtonStyle}" Click="AgePlus3_Click"/>
                                    <Button Content="+6" Style="{StaticResource StepButtonStyle}" Click="AgePlus6_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFF6F8">
                            <StackPanel>
                                <TextBlock Text="Income" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <TextBlock x:Name="IncomeValueText" Text="$0" Style="{StaticResource StepperValueStyle}"/>
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="-1K" Style="{StaticResource StepButtonStyle}" Click="IncomeMinus1000_Click"/>
                                    <Button Content="-5K" Style="{StaticResource StepButtonStyle}" Click="IncomeMinus5000_Click"/>
                                    <Button Content="-10K" Style="{StaticResource StepButtonStyle}" Click="IncomeMinus10000_Click"/>
                                    <Button Content="-100K" Style="{StaticResource StepButtonStyle}" Click="IncomeMinus100000_Click"/>
                                    <Button Content="+1K" Style="{StaticResource StepButtonStyle}" Click="IncomePlus1000_Click"/>
                                    <Button Content="+5K" Style="{StaticResource StepButtonStyle}" Click="IncomePlus5000_Click"/>
                                    <Button Content="+10K" Style="{StaticResource StepButtonStyle}" Click="IncomePlus10000_Click"/>
                                    <Button Content="+100K" Style="{StaticResource StepButtonStyle}" Click="IncomePlus100000_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF1FBFF">
                            <StackPanel>
                                <TextBlock Text="Years" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <TextBlock x:Name="YearsValueText" Text="0" Style="{StaticResource StepperValueStyle}"/>
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="-6" Style="{StaticResource StepButtonStyle}" Click="YearsMinus6_Click"/>
                                    <Button Content="-3" Style="{StaticResource StepButtonStyle}" Click="YearsMinus3_Click"/>
                                    <Button Content="-1" Style="{StaticResource StepButtonStyle}" Click="YearsMinus1_Click"/>
                                    <Button Content="+1" Style="{StaticResource StepButtonStyle}" Click="YearsPlus1_Click"/>
                                    <Button Content="+3" Style="{StaticResource StepButtonStyle}" Click="YearsPlus3_Click"/>
                                    <Button Content="+6" Style="{StaticResource StepButtonStyle}" Click="YearsPlus6_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFFFFBF2">
                            <StackPanel>
                                <TextBlock Text="Assets" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <TextBlock x:Name="AssetsValueText" Text="$0" Style="{StaticResource StepperValueStyle}"/>
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="-1K" Style="{StaticResource StepButtonStyle}" Click="AssetsMinus1000_Click"/>
                                    <Button Content="-5K" Style="{StaticResource StepButtonStyle}" Click="AssetsMinus5000_Click"/>
                                    <Button Content="-10K" Style="{StaticResource StepButtonStyle}" Click="AssetsMinus10000_Click"/>
                                    <Button Content="-100K" Style="{StaticResource StepButtonStyle}" Click="AssetsMinus100000_Click"/>
                                    <Button Content="+1K" Style="{StaticResource StepButtonStyle}" Click="AssetsPlus1000_Click"/>
                                    <Button Content="+5K" Style="{StaticResource StepButtonStyle}" Click="AssetsPlus5000_Click"/>
                                    <Button Content="+10K" Style="{StaticResource StepButtonStyle}" Click="AssetsPlus10000_Click"/>
                                    <Button Content="+100K" Style="{StaticResource StepButtonStyle}" Click="AssetsPlus100000_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFFDF3FF">
                            <StackPanel>
                                <TextBlock Text="Debt" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <TextBlock x:Name="DebtValueText" Text="$0" Style="{StaticResource StepperValueStyle}"/>
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="-1K" Style="{StaticResource StepButtonStyle}" Click="DebtMinus1000_Click"/>
                                    <Button Content="-5K" Style="{StaticResource StepButtonStyle}" Click="DebtMinus5000_Click"/>
                                    <Button Content="-10K" Style="{StaticResource StepButtonStyle}" Click="DebtMinus10000_Click"/>
                                    <Button Content="-100K" Style="{StaticResource StepButtonStyle}" Click="DebtMinus100000_Click"/>
                                    <Button Content="+1K" Style="{StaticResource StepButtonStyle}" Click="DebtPlus1000_Click"/>
                                    <Button Content="+5K" Style="{StaticResource StepButtonStyle}" Click="DebtPlus5000_Click"/>
                                    <Button Content="+10K" Style="{StaticResource StepButtonStyle}" Click="DebtPlus10000_Click"/>
                                    <Button Content="+100K" Style="{StaticResource StepButtonStyle}" Click="DebtPlus100000_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Background="#FFF4FFF8">
                            <StackPanel>
                                <TextBlock Text="Budget" Style="{StaticResource FieldLabelStyle}" HorizontalAlignment="Center" FontSize="15"/>
                                <TextBlock x:Name="BudgetValueText" Text="System Managed" Style="{StaticResource StepperValueStyle}"/>
                                <WrapPanel HorizontalAlignment="Center">
                                    <Button Content="-1K" Style="{StaticResource StepButtonStyle}" Click="BudgetMinus1000_Click"/>
                                    <Button Content="-5K" Style="{StaticResource StepButtonStyle}" Click="BudgetMinus5000_Click"/>
                                    <Button Content="-10K" Style="{StaticResource StepButtonStyle}" Click="BudgetMinus10000_Click"/>
                                    <Button Content="-100K" Style="{StaticResource StepButtonStyle}" Click="BudgetMinus100000_Click"/>
                                    <Button Content="+1K" Style="{StaticResource StepButtonStyle}" Click="BudgetPlus1000_Click"/>
                                    <Button Content="+5K" Style="{StaticResource StepButtonStyle}" Click="BudgetPlus5000_Click"/>
                                    <Button Content="+10K" Style="{StaticResource StepButtonStyle}" Click="BudgetPlus10000_Click"/>
                                    <Button Content="+100K" Style="{StaticResource StepButtonStyle}" Click="BudgetPlus100000_Click"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </UniformGrid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Voice Command" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock Text="Examples: age 30, income 100000, years 15, asset 0, debt 0, budget 30000"
                                   Foreground="#FF5F5F7A"
                                   Margin="0,0,0,6"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                        <DockPanel>
                            <TextBox x:Name="VoiceCommandTextBox"
                                     Height="30"
                                     Margin="0,0,6,0"
                                     Padding="8,4"
                                     FontSize="12"
                                     VerticalContentAlignment="Center"
                                     BorderBrush="#FFD8C8F4"
                                     BorderThickness="1"/>
                            <Button Content="Apply Voice Command"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="ApplyVoiceButton_Click"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Actions" Style="{StaticResource SectionHeaderStyle}"/>
                        <WrapPanel>
                            <Button Content="Run Simulation"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="RunSimulationButton_Click"
									IsEnabled="False" />
                            <Button Content="Save"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveButton_Click"/>
                            <Button Content="Load Stats"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="LoadStatsButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.8*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="ValidationSummaryBorder"
                        Grid.Column="0"
                        Style="{StaticResource CardBorderStyle}"
                        Background="#FFFFF0F0"
                        BorderBrush="#FFFFCACA"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Validation Summary"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Foreground="#FFC62828"/>
                        <TextBlock x:Name="ValidationSummaryTextBlock"
                                   Foreground="#FFB71C1C"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   MaxHeight="54"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Background="#FFF8F8FF">
                    <StackPanel>
                        <TextBlock Text="Status" Style="{StaticResource SectionHeaderStyle}"/>
                        <TextBlock x:Name="StatusTextBlock"
                                   Text="Ready."
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource CandyText}"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Background="#FFFDF9FF">
                <StackPanel>
                    <TextBlock Text="Results Panel" Style="{StaticResource SectionHeaderStyle}"/>

                    <UniformGrid Columns="2">
                        <StackPanel>

                            <TextBlock Text="Suggested Budget" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="SuggestedBudgetValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                            <TextBlock Text="Actual Budget" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="ActualBudgetValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                            <TextBlock Text="FI Age" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="FIAgeValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                            <TextBlock Text="FI Asset" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="FIAssetValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                            <TextBlock Text="Millionaire Age" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="MillionaireAgeValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                        </StackPanel>
                        <!--
                        <StackPanel Margin="0,0,8,0">
                            <TextBlock Text="Suggested Budget" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="SuggestedBudgetValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                            <TextBlock Text="Savings" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="SavingsValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>

                            <TextBlock Text="Netted Assets" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="NettedAssetsValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>

                            <TextBlock Text="FI Target Assets" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="FiTargetAssetsValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>

                            <TextBlock Text="FI Age" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="FiAgeValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>
                        </StackPanel>
						
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="Actual Budget" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="ActualBudgetValueText" Text="-" Style="{StaticResource ResultValueStyle}"/>

                            <TextBlock Text="Netted Debt" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="NettedDebtValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>

                            <TextBlock Text="Debt-Free Age" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="DebtFreeAgeValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>

                            <TextBlock Text="FI Asset" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="FiAssetValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>

                            <TextBlock Text="Millionaire Age" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="MillionaireAgeValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>
                        </StackPanel>
						-->
                    </UniformGrid>

                    <TextBlock Text="Flags" Style="{StaticResource ResultLabelStyle}" Margin="0,4,0,1"/>
                    <TextBlock x:Name="FlagsValueText"
                               Text="-"
                               Style="{StaticResource SmallResultValueStyle}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Background="#FFF9FDFF">
                <StackPanel>
                    <TextBlock Text="User Stats" Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Distinct User Count" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="DistinctUserCountValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Return Count" Style="{StaticResource ResultLabelStyle}"/>
                            <TextBlock x:Name="ReturnCountValueText" Text="-" Style="{StaticResource SmallResultValueStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Background="#FFF7FCFF">
                <StackPanel>
                    <TextBlock Text="Budget Behavior" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#FF4C4C68"
                               Text="Before save, budget may be system-managed. After save, the effective budget becomes persisted truth. If the user edits budget, that value becomes active for future simulation requests."/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>